extends ./layout/layout-default.pug

block content
	// Header
	header.masthead
		.container.d-flex.h-100.align-items-center
			.row
				h1 Survival of the Best Fit
	// About Section
	section.about-section.text-center
		.container
			.row
				.col-lg-8.mx-auto
					a.btn.btn-info.mx-auto.play-button(href='./game/', role='button') Bắt Đầu Chơi
					h4.clickMe (Trò chơi mất khoảng 6 phút)
				.col-lg-8.mx-auto
					h1 Thiên Vị Của Máy Móc Tồn Tại Khắp Nơi
					.cute-box
						h2 Phần mềm có thực sự trung lập?
						p
							b Survival of the Best Fit
							|  là một trò chơi giáo dục về thiên vị tuyển dụng trong AI. Chúng tôi muốn giải thích cách việc lạm dụng AI có thể khiến máy móc kế thừa những định kiến của con người và làm gia tăng sự bất bình đẳng. Phần lớn các cuộc tranh luận về AI coi nó như một mối đe dọa áp đặt lên chúng ta, thay vì là thứ mà chúng ta có quyền kiểm soát. Chúng tôi muốn thay đổi điều đó bằng cách giúp mọi người hiểu công nghệ và yêu cầu trách nhiệm giải trình cao hơn từ những người đang xây dựng các hệ thống phần mềm này.
						p
							| Built by
							a(href='http://gaborcsapo.com/') Gabor Csapo
							| ,
							a(href='https://www.linkedin.com/in/kimjihyun/') Jihyun Kim
							| ,
							a(href='https://www.mklasinc.com/') Miha Klasinc
							| , and
							a(href='https://aliaelkattan.com') Alia ElKattan
							| .

						p
							| Supported by the
							a(href='https://blog.mozilla.org/blog/2018/10/24/keeping-ai-accountable-with-science-fiction-documentaries-and-doodles-plus-225000/') Creative Media Award
							|  from
							a(href='https://foundation.mozilla.org/en/') Mozilla Foundation
							| .

						p
							| Featured on
							a(href="https://fortune.com/2019/07/16/confronting-bias-in-a-i-raceahead/") Fortune
							| ,
							a(href="https://medium.com/read-write-participate/would-an-algorithm-hire-you-or-ignore-your-resume-db315a873c91") Mozilla
							| , and
							a(href="https://bdtechtalks.com/2019/07/08/ai-bias-survival-of-the-best-fit/") Tech Talks.
	// Signup Section
	section#signup.signup-section.about-section
		.container
			.row
				.col-md-12.col-lg-8.mx-auto.text-center.padding-top
					h1 Tham Gia

					.cute-box
						h2
							| Chia sẻ dự án này

						h3.mb-3

							.share-button
								<div class="fb-share-button" data-href="https://survivalofthebestfit.com" data-layout="button" data-size="large">
								<a target="_blank" href="https://www.facebook.com/sharer/sharer.php?u=https%3A%2F%2Fsurvivalofthebestfit.com%2F&amp;src=sdkpreparse" class="fb-xfbml-parse-ignore">Share</a></div>

							.share-button
								<a href="https://twitter.com/share?ref_src=twsrc%5Etfw" class="twitter-share-button" data-size="large" data-text="Can you hire without bias? Play this ~6 min game to find out" data-url="https://survivalofthebestfit.com" data-via="sotbf_" data-related="sotbf_" data-show-count="false">Tweet</a>
								<script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>

							.share-button
								<script src="https://platform.linkedin.com/in.js" type="text/javascript">lang: en_US</script>
								<script type="IN/Share" data-url="https://survivalofthebestfit.com"></script>

						p
							| Hãy giúp chúng tôi chia sẻ dự án này để nhiều người hơn có thể hiểu về thiên vị thuật toán.


					.cute-box
						h2
							| Bạn phát hiện lỗi (bug)?
							i.fas.fa-bug.mb-2
						p
							| Đây là một dự án mã nguồn mở và chúng tôi rất trân trọng những phản hồi cũng như đóng góp từ cộng đồng.

						p
							| Giúp chúng tôi cải thiện bằng cách tạo một 
							a(href="https://github.com/survivalofthebestfit/survivalofthebestfit/issues/new") issue trên Github
							|  hoặc gửi pull request. Bạn cũng có thể
							a(href="https://twitter.com/sotbf_") tweet
							|  cho chúng tôi những ý tưởng và góp ý của bạn!

